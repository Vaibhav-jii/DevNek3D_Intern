# ─── App ───────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ──────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/devnek3d"

# ─── JWT ───────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_random_32+_char_secret_access
JWT_REFRESH_SECRET=change_me_to_a_random_32+_char_secret_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ─── Redis (optional) ──────────────────────────
# REDIS_URL=redis://localhost:6379
